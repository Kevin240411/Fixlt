generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  admin
  technician
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  CANCELLED
}

enum RepairPriority {
  HIGH
  MEDIUM
  LOW
}

model User {
  id           Int        @id @default(autoincrement())
  fullName     String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(technician)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       RepairOrder[]
}

model Client {
  id           Int           @id @default(autoincrement())
  fullName     String
  phone        String
  email        String?
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  repairOrders RepairOrder[]
}

model Device {
  id            Int           @id @default(autoincrement())
  brand         String
  model         String
  serialNumber  String        @unique
  reportedFault String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  repairOrders  RepairOrder[]
}

model RepairOrder {
  id          Int            @id @default(autoincrement())
  clientId    Int
  deviceId    Int
  createdById Int
  status      RepairStatus   @default(PENDING)
  priority    RepairPriority @default(MEDIUM)
  cost        Decimal?       @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client      Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  device      Device         @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([status, priority])
  @@index([clientId])
  @@index([deviceId])
}
